# OpenRouter API Configuration (REQUIRED)
# Get your free API key from: https://openrouter.ai/keys
# This key is used server-side only through the secure GraphQL API
GATSBY_OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: Add other API keys for enhanced features
# GATSBY_GITHUB_TOKEN=your_github_token_here
# GATSBY_ANALYTICS_ID=your_analytics_id_here

# Security Note:
# The OpenRouter API key is NEVER exposed to the client.
# All AI requests go through /api/ai-graphql endpoint with server-side authentication.
